# Supabase — public anon keys, exposed to the browser
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT"

# Server-side mirrors for the auth middleware (TanStack Start server fns)
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# Lovable AI Gateway — used for all text-mode LLM calls (insights, mock interviewer, project drafting)
LOVABLE_API_KEY="your-lovable-api-key"

# Google Gemini API — required for voice mode (Gemini Live).
# Without this, voice mode silently falls back to text mode.
# Get a key at https://aistudio.google.com
GEMINI_API_KEY=""
